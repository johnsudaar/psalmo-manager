<div class="flex items-center gap-4 mb-6">
  <%= link_to "← Participants", participants_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
  <h1 class="text-2xl font-semibold text-gray-900"><%= @person.full_name %></h1>
</div>

<div class="grid grid-cols-1 gap-6">
  <%# Personal info card %>
  <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
    <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-4">Informations personnelles</h2>
    <dl class="grid grid-cols-2 gap-4">
      <div>
        <dt class="text-xs text-gray-500">Email</dt>
        <dd class="text-sm font-medium text-gray-900"><%= @person.email || "—" %></dd>
      </div>
      <div>
        <dt class="text-xs text-gray-500">Téléphone</dt>
        <dd class="text-sm font-medium text-gray-900"><%= @person.phone || "—" %></dd>
      </div>
      <div>
        <dt class="text-xs text-gray-500">Date de naissance</dt>
        <dd class="text-sm font-medium text-gray-900">
          <%= @person.date_of_birth&.strftime("%d/%m/%Y") || "—" %>
        </dd>
      </div>
      <div>
        <dt class="text-xs text-gray-500">Âge (au début de l'édition)</dt>
        <dd class="text-sm font-medium text-gray-900">
          <% age = @person.age_on(current_edition.start_date) %>
          <%= age ? "#{age} ans" : "—" %>
        </dd>
      </div>
    </dl>
  </div>

  <%# Registrations %>
  <% @registrations.each do |registration| %>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
      <div class="flex items-start justify-between mb-4">
        <div>
          <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wide">
            Inscription — commande #<%= registration.order.helloasso_order_id %>
          </h2>
          <div class="mt-2 flex gap-3">
            <%= link_to "Ouvrir la commande",
                  order_path(registration.order),
                  class: "text-sm font-medium text-indigo-600 hover:text-indigo-800" %>
            <%= link_to "Modifier les ateliers",
                  new_workshop_substitution_path(registration_id: registration.id),
                  class: "text-sm font-medium text-indigo-600 hover:text-indigo-800" %>
          </div>
        </div>
        <div class="flex gap-2">
          <% if registration.is_unaccompanied_minor %>
            <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-yellow-100 text-yellow-800">Mineur non accompagné</span>
          <% end %>
          <% if registration.has_conflict %>
            <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-red-100 text-red-800">Conflit d'atelier</span>
          <% end %>
          <% if registration.excluded_from_stats %>
            <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-600">Hors stats</span>
          <% end %>
        </div>
      </div>

      <dl class="grid grid-cols-3 gap-4 mb-4">
        <div>
          <dt class="text-xs text-gray-500">Catégorie</dt>
          <dd class="text-sm font-medium text-gray-900 capitalize"><%= registration.age_category %></dd>
        </div>
        <div>
          <dt class="text-xs text-gray-500">Prix billet</dt>
          <dd class="text-sm font-medium text-gray-900"><%= format_euros(registration.ticket_price_cents) %></dd>
        </div>
        <div>
          <dt class="text-xs text-gray-500">Remise</dt>
          <dd class="text-sm font-medium text-gray-900"><%= format_euros(registration.discount_cents) %></dd>
        </div>
        <div>
          <dt class="text-xs text-gray-500">Prix net</dt>
          <dd class="text-sm font-medium text-gray-900"><%= format_euros(registration.actual_price_cents) %></dd>
        </div>
      </dl>

      <% if registration.is_unaccompanied_minor && registration.responsible_person_note.present? %>
        <div class="mt-3 p-3 bg-yellow-50 border border-yellow-200 rounded text-sm text-yellow-800">
          <strong>Personne responsable :</strong> <%= registration.responsible_person_note %>
        </div>
      <% end %>

      <% if registration.registration_workshops.any? %>
        <div class="mt-4">
          <p class="text-xs text-gray-500 mb-2">Ateliers</p>
          <div class="flex flex-wrap gap-2">
            <% registration.registration_workshops.each do |rw| %>
              <span class="inline-flex items-center px-2 py-1 rounded text-xs font-medium bg-indigo-50 text-indigo-700">
                <%= rw.workshop.name %>
              </span>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <% if @registrations.empty? %>
    <p class="text-sm text-gray-500">Aucune inscription pour cette édition.</p>
  <% end %>
</div>
