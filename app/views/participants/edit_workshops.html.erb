<% time_slot_labels = { "matin" => "Matin", "apres_midi" => "Après-midi", "journee" => "Journée" } %>
<% current_workshops = @registration.registration_workshops.includes(:workshop) %>
<% selected_workshop_ids = current_workshops.map(&:workshop_id) %>

<div class="max-w-2xl">
  <div class="flex items-center gap-4 mb-6">
    <%= link_to "← Retour", participant_path(@person), class: "text-sm text-gray-500 hover:text-gray-700" %>
    <h1 class="text-2xl font-semibold text-gray-900">Modifier les ateliers — <%= @person.full_name %></h1>
  </div>

  <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 mb-6">
    <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-4">Ateliers actuels</h2>
    <% if current_workshops.any? %>
      <ul class="space-y-1">
        <% current_workshops.each do |rw| %>
          <li class="text-sm text-gray-700">
            <span class="font-medium"><%= time_slot_labels[rw.workshop.time_slot] %></span>
            — <%= rw.workshop.name %>
            <% if @registration.has_workshop_override? %>
              <span class="text-amber-700">(changé)</span>
            <% end %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-sm text-gray-500">Aucun atelier actuellement.</p>
      <% if @registration.has_workshop_override? %>
        <p class="text-sm text-amber-700 mt-2">Cette inscription a un changement d'atelier manuel.</p>
      <% end %>
    <% end %>
  </div>

  <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
    <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-2">Choix des ateliers</h2>
    <p class="text-sm text-gray-500 mb-4">Selectionnez 0, 1 ou 2 ateliers. Maximum 2 ateliers, sur des créneaux distincts.</p>

    <%= form_with url: update_workshops_participant_path(@person, registration_id: @registration.id), method: :patch do |f| %>
      <div class="space-y-6">
        <% @workshops.group_by(&:time_slot).each do |time_slot, workshops| %>
          <div>
            <p class="text-sm font-medium text-gray-700 mb-2"><%= time_slot_labels[time_slot] %></p>
            <div class="space-y-2">
              <% workshops.each do |workshop| %>
                <label class="flex items-center gap-3 text-sm text-gray-700">
                  <%= check_box_tag "workshop_ids[]", workshop.id, selected_workshop_ids.include?(workshop.id), class: "rounded" %>
                  <span><%= workshop.name %></span>
                  <% if workshop.full? %>
                    <span class="text-xs text-orange-600">(complet)</span>
                  <% end %>
                </label>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>

      <div class="mt-6 flex gap-3">
        <%= f.submit "Enregistrer",
              class: "bg-indigo-600 text-white px-4 py-2 rounded hover:bg-indigo-700 cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>
