<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-semibold text-gray-900">Participants — <%= current_edition.name %></h1>
</div>

<%= turbo_frame_tag "participant_filter" do %>
  <%= form_with url: participants_path, method: :get,
        data: { controller: "filter-form" },
        class: "bg-white rounded-lg shadow-sm border border-gray-200 p-4 mb-6" do |f| %>
    <div class="flex flex-wrap gap-4 items-end">
      <div>
        <%= f.label :q, "Recherche", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :q, value: params[:q],
              placeholder: "Nom, prénom, email…",
              class: "border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-indigo-500",
              data: { action: "change->filter-form#change" } %>
      </div>

      <div>
        <%= f.label :age_category, "Catégorie", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.select :age_category,
              [["Tous", ""], ["Enfant", "enfant"], ["Adulte", "adulte"]],
              { selected: params[:age_category] },
              class: "border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-indigo-500",
              data: { action: "change->filter-form#change" } %>
      </div>

      <div>
        <%= f.label :workshop_id, "Atelier", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.select :workshop_id,
              current_edition.workshops.order(:time_slot, :name).map { |w| [w.name, w.id] },
              { include_blank: "Tous", selected: params[:workshop_id] },
              class: "border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-indigo-500",
              data: { action: "change->filter-form#change" } %>
      </div>

      <div class="flex items-end gap-4">
        <label class="flex items-center gap-2 text-sm text-gray-700 pb-2">
          <%= f.check_box :unaccompanied_minors, checked: params[:unaccompanied_minors] == "1", class: "rounded",
                data: { action: "change->filter-form#change" } %>
          Mineurs non accompagnés
        </label>

        <label class="flex items-center gap-2 text-sm text-gray-700 pb-2">
          <%= f.check_box :with_conflicts, checked: params[:with_conflicts] == "1", class: "rounded",
                data: { action: "change->filter-form#change" } %>
          Avec conflits
        </label>

        <label class="flex items-center gap-2 text-sm text-gray-700 pb-2">
          <%= f.check_box :excluded_from_stats, checked: params[:excluded_from_stats] == "1", class: "rounded",
                data: { action: "change->filter-form#change" } %>
          Exclus des stats
        </label>
      </div>

      <%= f.submit "Filtrer", class: "bg-white text-gray-700 border border-gray-300 px-4 py-2 rounded hover:bg-gray-50 cursor-pointer" %>
    </div>
  <% end %>
  <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-sm font-semibold text-gray-500 uppercase tracking-wide">Nom</th>
          <th class="px-6 py-3 text-left text-sm font-semibold text-gray-500 uppercase tracking-wide">Email</th>
          <th class="px-6 py-3 text-left text-sm font-semibold text-gray-500 uppercase tracking-wide">Téléphone</th>
          <th class="px-6 py-3 text-left text-sm font-semibold text-gray-500 uppercase tracking-wide">Naissance</th>
          <th class="px-6 py-3 text-left text-sm font-semibold text-gray-500 uppercase tracking-wide">Catégorie</th>
          <th class="px-6 py-3 text-left text-sm font-semibold text-gray-500 uppercase tracking-wide">Ateliers</th>
          <th class="px-6 py-3 text-left text-sm font-semibold text-gray-500 uppercase tracking-wide">Flags</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <% @people.each_with_index do |person, i| %>
          <% registrations = person.registrations.select { |r| r.edition_id == current_edition.id } %>
          <% workshops_list = registrations.flat_map { |r| r.workshops.map(&:name) }.uniq %>
          <% has_conflict = registrations.any?(&:has_conflict) %>
          <% is_minor = registrations.any?(&:is_unaccompanied_minor) %>
          <tr class="<%= i.even? ? 'bg-white' : 'bg-gray-50' %>">
            <td class="px-6 py-4 text-sm font-medium text-gray-900">
              <%= link_to person.full_name, participant_path(person),
                    class: "text-indigo-600 hover:text-indigo-800",
                    data: { turbo_frame: "_top" } %>
            </td>
            <td class="px-6 py-4 text-sm text-gray-700"><%= person.email %></td>
            <td class="px-6 py-4 text-sm text-gray-700"><%= person.phone %></td>
            <td class="px-6 py-4 text-sm text-gray-700">
              <%= person.date_of_birth&.strftime("%d/%m/%Y") || "—" %>
            </td>
            <td class="px-6 py-4 text-sm text-gray-700 capitalize">
              <%= registrations.map(&:age_category).uniq.join(", ") %>
            </td>
            <td class="px-6 py-4 text-sm text-gray-700"><%= workshops_list.join(", ").presence || "—" %></td>
            <td class="px-6 py-4 text-sm">
              <div class="flex gap-1 flex-wrap">
                <% if has_conflict %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-red-100 text-red-800">Conflit</span>
                <% end %>
                <% if is_minor %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-yellow-100 text-yellow-800">Mineur</span>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
        <% if @people.empty? %>
          <tr>
            <td colspan="7" class="px-6 py-8 text-center text-sm text-gray-500">Aucun participant trouvé.</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <% if @pagy.pages > 1 %>
    <div class="mt-4 flex justify-center text-sm">
      <%== pagy_nav(@pagy) %>
    </div>
  <% end %>
<% end %>
