<div class="max-w-xl">
  <div class="flex items-center gap-4 mb-6">
    <%= link_to "← Retour", workshop_path(@workshop), class: "text-sm text-gray-500 hover:text-gray-700" %>
    <h1 class="text-2xl font-semibold text-gray-900">Modifier — <%= @workshop.name %></h1>
  </div>

  <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
    <% if @workshop.errors.any? || @error %>
      <div class="mb-4 px-4 py-3 rounded bg-red-50 border border-red-200 text-red-800 text-sm">
        <% if @workshop.errors.any? %>
          <ul class="list-disc list-inside space-y-1">
            <% @workshop.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        <% elsif @error %>
          <%= @error %>
        <% end %>
      </div>
    <% end %>

    <%= form_with model: @workshop, url: workshop_path(@workshop), method: :patch do |f| %>
      <div class="space-y-4">
        <div>
          <%= f.label :name, "Nom", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :name,
                class: "block w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-indigo-500",
                value: @workshop.name %>
        </div>

        <div>
          <%= f.label :time_slot, "Créneau", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.select :time_slot,
                [["Matin", "matin"], ["Après-midi", "apres_midi"], ["Journée", "journee"]],
                { selected: @workshop.time_slot },
                class: "block w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
        </div>

        <div>
          <%= f.label :capacity, "Capacité (optionnel)", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.number_field :capacity,
                class: "block w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-indigo-500",
                value: @workshop.capacity,
                min: 1 %>
        </div>

        <div>
          <%= f.label :helloasso_column_name, "Colonne HelloAsso (optionnel)", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :helloasso_column_name,
                class: "block w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-indigo-500",
                value: @workshop.helloasso_column_name %>
        </div>

        <div class="pt-2">
          <%= f.submit "Enregistrer",
                class: "bg-indigo-600 text-white px-4 py-2 rounded hover:bg-indigo-700 cursor-pointer" %>
          <%= link_to "Annuler", workshop_path(@workshop),
                class: "ml-3 bg-white text-gray-700 border border-gray-300 px-4 py-2 rounded hover:bg-gray-50" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
