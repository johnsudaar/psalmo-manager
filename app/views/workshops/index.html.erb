<% time_slot_labels = { "matin" => "Matin", "apres_midi" => "Après-midi", "journee" => "Journée" } %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-semibold text-gray-900">Ateliers — <%= current_edition.name %></h1>
  <%= link_to "Nouvel atelier", new_workshop_path,
        class: "bg-indigo-600 text-white px-4 py-2 rounded hover:bg-indigo-700" %>
</div>

<div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-6 py-3 text-left text-sm font-semibold text-gray-500 uppercase tracking-wide">Nom</th>
        <th class="px-6 py-3 text-left text-sm font-semibold text-gray-500 uppercase tracking-wide">Créneau</th>
        <th class="px-6 py-3 text-left text-sm font-semibold text-gray-500 uppercase tracking-wide">Capacité</th>
        <th class="px-6 py-3 text-left text-sm font-semibold text-gray-500 uppercase tracking-wide">Participants inscrits</th>
        <th class="px-6 py-3 text-left text-sm font-semibold text-gray-500 uppercase tracking-wide">Taux de remplissage</th>
        <th class="px-6 py-3 text-left text-sm font-semibold text-gray-500 uppercase tracking-wide">Actions</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200">
      <% @workshops.each_with_index do |workshop, i| %>
        <% count = workshop.registrations.count %>
        <% fill = workshop.fill_rate %>
        <tr class="<%= i.even? ? 'bg-white' : 'bg-gray-50' %>">
          <td class="px-6 py-4 text-sm font-medium text-gray-900"><%= workshop.name %></td>
          <td class="px-6 py-4 text-sm text-gray-700"><%= time_slot_labels[workshop.time_slot] %></td>
          <td class="px-6 py-4 text-sm text-gray-700"><%= workshop.capacity || "—" %></td>
          <td class="px-6 py-4 text-sm text-gray-700"><%= count %></td>
          <td class="px-6 py-4 text-sm text-gray-700">
            <% if fill %>
              <% bar_color = fill >= 100 ? "bg-red-500" : fill >= 80 ? "bg-orange-400" : "bg-green-500" %>
              <div class="flex items-center gap-2">
                <div class="w-24 h-2 bg-gray-200 rounded-full overflow-hidden">
                  <div class="<%= bar_color %> h-2 rounded-full" style="width: <%= [fill, 100].min %>%"></div>
                </div>
                <span><%= fill %>%</span>
              </div>
            <% else %>
              —
            <% end %>
          </td>
          <td class="px-6 py-4 text-sm flex gap-3">
            <%= link_to "Voir", workshop_path(workshop),
                  class: "text-indigo-600 hover:text-indigo-800 font-medium" %>
            <%= link_to "Modifier", edit_workshop_path(workshop),
                  class: "text-gray-600 hover:text-gray-800 font-medium" %>
            <%= button_to "Supprimer", workshop_path(workshop), method: :delete,
                  class: "text-red-600 hover:text-red-800 font-medium bg-transparent border-0 p-0 cursor-pointer",
                  data: {
                    controller: "confirm-delete",
                    action: "click->confirm-delete#confirm",
                    confirm_message: "Supprimer l'atelier « #{workshop.name} » ?"
                  } %>
          </td>
        </tr>
      <% end %>
      <% if @workshops.empty? %>
        <tr>
          <td colspan="6" class="px-6 py-8 text-center text-sm text-gray-500">Aucun atelier pour cette édition.</td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
