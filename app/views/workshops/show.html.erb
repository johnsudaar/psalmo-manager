<% time_slot_labels = { "matin" => "Matin", "apres_midi" => "Après-midi", "journee" => "Journée" } %>
<% count = @workshop.registrations.count %>
<% fill = @workshop.fill_rate %>
<% revenue = @workshop.registration_workshops.sum(:price_paid_cents) %>

<div class="flex items-center justify-between mb-6">
  <div class="flex items-center gap-4">
    <%= link_to "← Ateliers", workshops_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
    <h1 class="text-2xl font-semibold text-gray-900"><%= @workshop.name %></h1>
  </div>
  <div class="flex gap-3">
    <%= link_to "Modifier", edit_workshop_path(@workshop),
          class: "bg-white text-gray-700 border border-gray-300 px-4 py-2 rounded hover:bg-gray-50" %>
    <%= button_to "Supprimer", workshop_path(@workshop), method: :delete,
          class: "bg-red-600 text-white px-4 py-2 rounded hover:bg-red-700 cursor-pointer",
          data: {
            controller: "confirm-delete",
            action: "click->confirm-delete#confirm",
            confirm_message: "Supprimer l'atelier « #{@workshop.name} » ?"
          } %>
  </div>
</div>

<div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 mb-6">
  <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-4">Informations</h2>
  <dl class="grid grid-cols-2 gap-4">
    <div>
      <dt class="text-xs text-gray-500">Créneau</dt>
      <dd class="text-sm font-medium text-gray-900"><%= time_slot_labels[@workshop.time_slot] %></dd>
    </div>
    <div>
      <dt class="text-xs text-gray-500">Capacité</dt>
      <dd class="text-sm font-medium text-gray-900"><%= @workshop.capacity || "Illimitée" %></dd>
    </div>
    <div>
      <dt class="text-xs text-gray-500">Participants inscrits</dt>
      <dd class="text-sm font-medium text-gray-900"><%= count %></dd>
    </div>
    <div>
      <dt class="text-xs text-gray-500">Taux de remplissage</dt>
      <dd class="text-sm font-medium text-gray-900">
        <% if fill %>
          <% bar_color = fill >= 100 ? "bg-red-500" : fill >= 80 ? "bg-orange-400" : "bg-green-500" %>
          <div class="flex items-center gap-2">
            <div class="w-24 h-2 bg-gray-200 rounded-full overflow-hidden">
              <div class="<%= bar_color %> h-2 rounded-full" style="width: <%= [fill, 100].min %>%"></div>
            </div>
            <span><%= fill %>%</span>
          </div>
        <% else %>
          —
        <% end %>
      </dd>
    </div>
    <div>
      <dt class="text-xs text-gray-500">Recettes totales</dt>
      <dd class="text-sm font-medium text-gray-900"><%= format_euros(revenue) %></dd>
    </div>
  </dl>
</div>

<div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
  <div class="px-6 py-4 border-b border-gray-200">
    <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wide">Participants inscrits</h2>
  </div>
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-6 py-3 text-left text-sm font-semibold text-gray-500 uppercase tracking-wide">Nom</th>
        <th class="px-6 py-3 text-left text-sm font-semibold text-gray-500 uppercase tracking-wide">Catégorie</th>
        <th class="px-6 py-3 text-left text-sm font-semibold text-gray-500 uppercase tracking-wide">Email</th>
        <th class="px-6 py-3 text-left text-sm font-semibold text-gray-500 uppercase tracking-wide">Téléphone</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200">
      <% @registrations.each_with_index do |registration, i| %>
        <tr class="<%= i.even? ? 'bg-white' : 'bg-gray-50' %>">
          <td class="px-6 py-4 text-sm font-medium text-gray-900">
            <%= link_to registration.person.full_name, participant_path(registration.person),
                  class: "text-indigo-600 hover:text-indigo-800" %>
          </td>
          <td class="px-6 py-4 text-sm text-gray-700 capitalize"><%= registration.age_category %></td>
          <td class="px-6 py-4 text-sm text-gray-700"><%= registration.person.email %></td>
          <td class="px-6 py-4 text-sm text-gray-700"><%= registration.person.phone %></td>
        </tr>
      <% end %>
      <% if @registrations.empty? %>
        <tr>
          <td colspan="4" class="px-6 py-8 text-center text-sm text-gray-500">Aucun participant inscrit.</td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
