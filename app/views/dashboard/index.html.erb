<% if current_edition.nil? %>
  <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-12 text-center">
    <p class="text-gray-500 mb-4">Aucune édition disponible.</p>
    <%= link_to "Créer une édition", new_edition_path,
          class: "bg-indigo-600 text-white px-4 py-2 rounded hover:bg-indigo-700" %>
  </div>
<% else %>

<div class="mb-6">
  <h1 class="text-2xl font-semibold text-gray-900">Tableau de bord</h1>
  <p class="text-sm text-gray-500 mt-1"><%= current_edition.name %></p>
</div>

<%# ===== Row 1: Summary cards ===== %>
<div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">

  <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
    <p class="text-sm font-semibold text-gray-500 uppercase tracking-wide">Billetterie</p>
    <p class="mt-2 text-3xl font-bold text-gray-900"><%= format_euros(@stats.total_billetterie_cents) %></p>
  </div>

  <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
    <p class="text-sm font-semibold text-gray-500 uppercase tracking-wide">Ateliers</p>
    <p class="mt-2 text-3xl font-bold text-gray-900"><%= format_euros(@stats.total_ateliers_cents) %></p>
  </div>

  <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
    <p class="text-sm font-semibold text-gray-500 uppercase tracking-wide">Total général</p>
    <p class="mt-2 text-3xl font-bold text-indigo-600"><%= format_euros(@stats.total_revenue_cents) %></p>
  </div>

</div>

<%# ===== Row 2: Participants + quick links ===== %>
<div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">

  <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
    <p class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-3">Participants (hors exclus)</p>
    <p class="text-3xl font-bold text-gray-900"><%= @stats.total_participants %></p>
    <div class="mt-3 flex gap-6 text-sm text-gray-600">
      <span>Enfants&nbsp;: <strong><%= @stats.participants_enfant %></strong></span>
      <span>Adultes&nbsp;: <strong><%= @stats.participants_adulte %></strong></span>
    </div>
  </div>

  <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
    <p class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-3">Alertes</p>
    <ul class="space-y-2 text-sm">
      <li>
        <%= link_to participants_path(unaccompanied_minors: 1),
              class: "flex items-center justify-between text-gray-700 hover:text-indigo-600" do %>
          <span>Mineurs non accompagnés</span>
          <span class="font-semibold <%= @stats.unaccompanied_minors_count > 0 ? 'text-orange-600' : 'text-gray-400' %>">
            <%= @stats.unaccompanied_minors_count %>
          </span>
        <% end %>
      </li>
      <li>
        <%= link_to participants_path(with_conflicts: 1),
              class: "flex items-center justify-between text-gray-700 hover:text-indigo-600" do %>
          <span>Conflits d'atelier</span>
          <span class="font-semibold <%= @stats.conflicts_count > 0 ? 'text-red-600' : 'text-gray-400' %>">
            <%= @stats.conflicts_count %>
          </span>
        <% end %>
      </li>
    </ul>
  </div>

  <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
    <p class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-3">5 dernières inscriptions</p>
    <% if @stats.recent_registrations.any? %>
      <ul class="space-y-1 text-sm text-gray-700">
        <% @stats.recent_registrations.each do |reg| %>
          <li class="flex items-center justify-between">
            <%= link_to reg.person.full_name, participant_path(reg.person),
                  class: "truncate hover:text-indigo-600 max-w-[140px]" %>
            <span class="text-gray-400 text-xs shrink-0 ml-2">
              <%= reg.order.order_date.strftime("%d/%m") %>
            </span>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-sm text-gray-400">Aucune inscription.</p>
    <% end %>
  </div>

</div>

<%# ===== Row 3: Weekly cadence chart ===== %>
<div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 mb-6">
  <p class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-4">Inscriptions par semaine</p>
  <% if @stats.weekly_cadence.any? %>
    <%= line_chart @stats.weekly_cadence,
          height: "200px",
          colors: [ "#4f46e5" ],
          library: { scales: { y: { beginAtZero: true } } } %>
  <% else %>
    <p class="text-sm text-gray-400">Aucune donnée disponible.</p>
  <% end %>
</div>

<%# ===== Row 4: Workshop fill rates ===== %>
<div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
  <div class="px-6 py-4 border-b border-gray-200">
    <p class="text-sm font-semibold text-gray-500 uppercase tracking-wide">Taux de remplissage des ateliers</p>
  </div>
  <% fill_rates = @stats.workshop_fill_rates %>
  <% if fill_rates.any? %>
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-sm font-semibold text-gray-500 uppercase tracking-wide">Atelier</th>
          <th class="px-6 py-3 text-left text-sm font-semibold text-gray-500 uppercase tracking-wide">Créneau</th>
          <th class="px-6 py-3 text-left text-sm font-semibold text-gray-500 uppercase tracking-wide">Inscrits</th>
          <th class="px-6 py-3 text-left text-sm font-semibold text-gray-500 uppercase tracking-wide">Capacité</th>
          <th class="px-6 py-3 text-left text-sm font-semibold text-gray-500 uppercase tracking-wide">Remplissage</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <% slot_labels = { "matin" => "Matin", "apres_midi" => "Après-midi", "journee" => "Journée" } %>
        <% fill_rates.each_with_index do |row, i| %>
          <tr class="<%= i.even? ? 'bg-white' : 'bg-gray-50' %>">
            <td class="px-6 py-3 text-sm font-medium text-gray-900">
              <%= link_to row[:workshop].name, workshop_path(row[:workshop]),
                    class: "hover:text-indigo-600" %>
            </td>
            <td class="px-6 py-3 text-sm text-gray-600"><%= slot_labels[row[:workshop].time_slot] %></td>
            <td class="px-6 py-3 text-sm text-gray-700"><%= row[:enrolled] %></td>
            <td class="px-6 py-3 text-sm text-gray-700"><%= row[:capacity] || "—" %></td>
            <td class="px-6 py-3 text-sm text-gray-700">
              <% if row[:fill_rate] %>
                <% bar_color = row[:fill_rate] >= 100 ? "bg-red-500" : row[:fill_rate] >= 80 ? "bg-orange-400" : "bg-green-500" %>
                <div class="flex items-center gap-2">
                  <div class="w-24 h-2 bg-gray-200 rounded-full overflow-hidden">
                    <div class="<%= bar_color %> h-2 rounded-full" style="width: <%= [ row[:fill_rate], 100 ].min %>%"></div>
                  </div>
                  <span><%= row[:fill_rate] %>%</span>
                </div>
              <% else %>
                <span class="text-gray-400">Sans limite</span>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="px-6 py-8 text-sm text-gray-400 text-center">Aucun atelier pour cette édition.</p>
  <% end %>
</div>

<% end %>
