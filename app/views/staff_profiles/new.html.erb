<div class="max-w-xl">
  <div class="flex items-center gap-4 mb-6">
    <%= link_to "← Staff", staff_profiles_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
    <h1 class="text-2xl font-semibold text-gray-900">Nouvelle fiche staff</h1>
  </div>

  <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
    <% if @error %>
      <div class="mb-4 px-4 py-3 rounded bg-red-50 border border-red-200 text-red-800 text-sm">
        <%= @error %>
      </div>
    <% end %>

    <%= form_with model: @staff_profile, url: staff_profiles_path, method: :post do |f| %>
      <div class="space-y-4">
        <div>
          <%= f.label :person_id, "Animateur", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <% people = Person.order(:last_name, :first_name) %>
          <%= f.select :person_id,
                people.map { |p| ["#{p.full_name} (#{p.email})", p.id] },
                { include_blank: "— Choisir une personne —" },
                class: "block w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
        </div>

        <div class="pt-2">
          <%= f.submit "Créer la fiche",
                class: "bg-indigo-600 text-white px-4 py-2 rounded hover:bg-indigo-700 cursor-pointer" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
