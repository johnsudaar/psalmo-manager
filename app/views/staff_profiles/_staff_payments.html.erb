<%# locals: staff_profile %>
<div id="staff_payments" class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
  <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
    <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wide">Versements</h2>
  </div>

  <% if staff_profile.staff_payments.any? %>
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-sm font-semibold text-gray-500 uppercase tracking-wide">Date</th>
          <th class="px-6 py-3 text-left text-sm font-semibold text-gray-500 uppercase tracking-wide">Montant</th>
          <th class="px-6 py-3 text-left text-sm font-semibold text-gray-500 uppercase tracking-wide">Commentaire</th>
          <th class="px-6 py-3 text-left text-sm font-semibold text-gray-500 uppercase tracking-wide">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <% staff_profile.staff_payments.order(:date).each_with_index do |payment, i| %>
          <tr class="<%= i.even? ? 'bg-white' : 'bg-gray-50' %>">
            <td class="px-6 py-4 text-sm text-gray-700"><%= payment.date&.strftime("%d/%m/%Y") %></td>
            <td class="px-6 py-4 text-sm text-gray-700"><%= format_euros(payment.amount_cents) %></td>
            <td class="px-6 py-4 text-sm text-gray-700"><%= payment.comment.presence || "—" %></td>
            <td class="px-6 py-4 text-sm">
              <%= button_to "Supprimer",
                    staff_profile_staff_payment_path(staff_profile, payment),
                    method: :delete,
                    class: "text-red-600 hover:text-red-800 font-medium bg-transparent border-0 p-0 cursor-pointer",
                    data: {
                      controller: "confirm-delete",
                      action: "click->confirm-delete#confirm",
                      confirm_message: "Supprimer ce versement ?"
                    } %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="px-6 py-4 text-sm text-gray-500">Aucun versement enregistré.</p>
  <% end %>

  <div class="px-6 py-4 border-t border-gray-200 bg-gray-50">
    <p class="text-sm font-medium text-gray-700 mb-3">Ajouter un versement</p>
    <%= form_with url: staff_profile_staff_payments_path(staff_profile), method: :post do |f| %>
      <div class="flex flex-wrap gap-3 items-end">
        <div>
          <%= f.label :date, "Date", class: "block text-xs text-gray-600 mb-1" %>
          <%= f.date_field :date,
                name: "staff_payment[date]",
                class: "border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
        </div>
        <div>
          <%= f.label :amount_cents, "Montant (centimes)", class: "block text-xs text-gray-600 mb-1" %>
          <%= f.number_field :amount_cents,
                name: "staff_payment[amount_cents]",
                class: "border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-indigo-500",
                min: 0 %>
        </div>
        <div>
          <%= f.label :comment, "Commentaire", class: "block text-xs text-gray-600 mb-1" %>
          <%= f.text_field :comment,
                name: "staff_payment[comment]",
                class: "border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
        </div>
        <%= f.submit "Ajouter",
              class: "bg-indigo-600 text-white px-4 py-2 rounded hover:bg-indigo-700 cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>
