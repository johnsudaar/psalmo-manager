<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-semibold text-gray-900">Exports</h1>
</div>

<div class="bg-white rounded-lg shadow-sm border border-gray-200 divide-y divide-gray-200">

  <div class="px-6 py-4 flex items-center justify-between">
    <div>
      <p class="text-sm font-medium text-gray-900">Liste des participants</p>
      <p class="text-xs text-gray-500 mt-0.5">Prénom, Nom, Email, Téléphone, DDN, Catégorie, Ateliers, Exclu stats, Mineur seul</p>
    </div>
    <%= link_to "Télécharger CSV", participants_export_path,
          class: "bg-indigo-600 text-white px-4 py-2 rounded text-sm hover:bg-indigo-700 transition-colors" %>
  </div>

  <div class="px-6 py-4 flex items-center justify-between">
    <div>
      <p class="text-sm font-medium text-gray-900">Listes par atelier</p>
      <p class="text-xs text-gray-500 mt-0.5">Feuilles de présence — une section par atelier</p>
    </div>
    <%= link_to "Télécharger CSV", workshop_roster_csv_export_path,
          class: "bg-indigo-600 text-white px-4 py-2 rounded text-sm hover:bg-indigo-700 transition-colors" %>
  </div>

  <div class="px-6 py-4 flex items-center justify-between">
    <div>
      <p class="text-sm font-medium text-gray-900">Récapitulatif staff</p>
      <p class="text-xs text-gray-500 mt-0.5">Tous les champs financiers par animateur(s)</p>
    </div>
    <%= link_to "Télécharger CSV", staff_summary_export_path,
          class: "bg-indigo-600 text-white px-4 py-2 rounded text-sm hover:bg-indigo-700 transition-colors" %>
  </div>

  <div class="px-6 py-4 flex items-center justify-between">
    <div>
      <p class="text-sm font-medium text-gray-900">Rapport financier</p>
      <p class="text-xs text-gray-500 mt-0.5">Indicateurs agrégés de l'édition (billetterie, remises, totaux)</p>
    </div>
    <%= link_to "Télécharger CSV", financial_report_export_path,
          class: "bg-indigo-600 text-white px-4 py-2 rounded text-sm hover:bg-indigo-700 transition-colors" %>
  </div>

  <div class="px-6 py-4 flex items-center justify-between">
    <div>
      <p class="text-sm font-medium text-gray-900">Commandes HelloAsso</p>
      <p class="text-xs text-gray-500 mt-0.5">Date, payeur, participants par commande</p>
    </div>
    <%= link_to "Télécharger CSV", orders_csv_export_path,
          class: "bg-indigo-600 text-white px-4 py-2 rounded text-sm hover:bg-indigo-700 transition-colors" %>
  </div>

</div>
