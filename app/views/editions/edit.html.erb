<div class="max-w-xl">
  <div class="flex items-center gap-4 mb-6">
    <%= link_to "← Retour", editions_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
    <h1 class="text-2xl font-semibold text-gray-900">Paramètres — <%= @edition.name %></h1>
  </div>

  <p class="text-sm text-gray-500 mb-4">(Sauvegarde automatique)</p>

  <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
    <%= form_with model: @edition, url: edition_path(@edition), method: :patch do |f| %>
      <div class="space-y-4">

        <div>
          <%= f.label :name, "Nom", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :name,
                class: "block w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-indigo-500",
                value: @edition.name,
                data: {
                  controller: "autosave",
                  action: "blur->autosave#save",
                  autosave_url_value: edition_path(@edition),
                  autosave_param_value: "edition[name]"
                } %>
          <div id="field_error_name" class="text-red-600 text-sm mt-1"></div>
        </div>

        <div>
          <%= f.label :year, "Année", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.number_field :year,
                class: "block w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-indigo-500",
                value: @edition.year,
                data: {
                  controller: "autosave",
                  action: "blur->autosave#save",
                  autosave_url_value: edition_path(@edition),
                  autosave_param_value: "edition[year]"
                } %>
          <div id="field_error_year" class="text-red-600 text-sm mt-1"></div>
        </div>

        <div>
          <%= f.label :start_date, "Date de début", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.date_field :start_date,
                class: "block w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-indigo-500",
                value: @edition.start_date,
                data: {
                  controller: "autosave",
                  action: "change->autosave#save",
                  autosave_url_value: edition_path(@edition),
                  autosave_param_value: "edition[start_date]"
                } %>
          <div id="field_error_start_date" class="text-red-600 text-sm mt-1"></div>
        </div>

        <div>
          <%= f.label :end_date, "Date de fin", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.date_field :end_date,
                class: "block w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-indigo-500",
                value: @edition.end_date,
                data: {
                  controller: "autosave",
                  action: "change->autosave#save",
                  autosave_url_value: edition_path(@edition),
                  autosave_param_value: "edition[end_date]"
                } %>
          <div id="field_error_end_date" class="text-red-600 text-sm mt-1"></div>
        </div>

        <div>
          <%= f.label :helloasso_form_slug, "Slug HelloAsso", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :helloasso_form_slug,
                class: "block w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-indigo-500",
                value: @edition.helloasso_form_slug,
                data: {
                  controller: "autosave",
                  action: "blur->autosave#save",
                  autosave_url_value: edition_path(@edition),
                  autosave_param_value: "edition[helloasso_form_slug]"
                } %>
          <div id="field_error_helloasso_form_slug" class="text-red-600 text-sm mt-1"></div>
        </div>

        <div>
          <%= f.label :km_rate_cents, "Taux km (€/km)", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :km_rate_cents,
                class: "block w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-indigo-500",
                value: decimal_km_rate(@edition.km_rate_cents),
                inputmode: "decimal",
                data: {
                  controller: "autosave currency-input",
                  action: "blur->autosave#save",
                  autosave_url_value: edition_path(@edition),
                  autosave_param_value: "edition[km_rate_cents]"
                } %>
          <div id="field_error_km_rate_cents" class="text-red-600 text-sm mt-1"></div>
        </div>

        <div>
          <%= f.label :transport_modes, "Modes de transport (un par ligne)", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_area :transport_modes,
                class: "block w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-indigo-500",
                value: @edition.transport_mode_options.join("\n"),
                rows: 5,
                data: {
                  controller: "autosave",
                  action: "blur->autosave#save",
                  autosave_url_value: edition_path(@edition),
                  autosave_param_value: "edition[transport_modes]"
                } %>
          <div id="field_error_transport_modes" class="text-red-600 text-sm mt-1"></div>
        </div>

        <div>
          <%= f.label :allowance_labels, "Libellés d'indemnité (un par ligne)", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_area :allowance_labels,
                class: "block w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-indigo-500",
                value: @edition.allowance_label_options.join("\n"),
                rows: 5,
                data: {
                  controller: "autosave",
                  action: "blur->autosave#save",
                  autosave_url_value: edition_path(@edition),
                  autosave_param_value: "edition[allowance_labels]"
                } %>
          <div id="field_error_allowance_labels" class="text-red-600 text-sm mt-1"></div>
        </div>

        <div>
          <%= f.label :logo, "Logo", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <% if @edition.logo.attached? %>
            <div class="mb-3 rounded border border-gray-200 bg-gray-50 p-3">
              <p class="text-sm text-gray-500 mb-2"><%= @edition.logo.filename.to_s %></p>
              <%= image_tag rails_blob_path(@edition.logo, disposition: "inline"),
                    alt: "Logo de l'édition",
                    class: "max-h-24 w-auto" %>
            </div>
          <% end %>
          <%= f.file_field :logo,
                class: "block w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-indigo-500",
                accept: "image/png,image/jpeg,image/webp",
                data: {
                  controller: "file-submit",
                  action: "change->file-submit#submit"
                } %>
          <div id="field_error_logo" class="text-red-600 text-sm mt-1"></div>
        </div>


      </div>
    <% end %>
  </div>
</div>
