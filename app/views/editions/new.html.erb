<div class="max-w-xl">
  <div class="flex items-center gap-4 mb-6">
    <%= link_to "← Retour", editions_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
    <h1 class="text-2xl font-semibold text-gray-900">Nouvelle édition</h1>
  </div>

  <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
    <% if @edition.errors.any? || @error %>
      <div class="mb-4 px-4 py-3 rounded bg-red-50 border border-red-200 text-red-800 text-sm">
        <% if @edition.errors.any? %>
          <ul class="list-disc list-inside space-y-1">
            <% @edition.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        <% elsif @error %>
          <%= @error %>
        <% end %>
      </div>
    <% end %>

    <%= form_with model: @edition, url: editions_path, method: :post do |f| %>
      <div class="space-y-4">
        <div>
          <%= f.label :name, "Nom", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :name, class: "block w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-indigo-500",
                value: @edition.name %>
        </div>

        <div>
          <%= f.label :year, "Année", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.number_field :year, class: "block w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-indigo-500",
                value: @edition.year %>
        </div>

        <div>
          <%= f.label :start_date, "Date de début", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.date_field :start_date, class: "block w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-indigo-500",
                value: @edition.start_date %>
        </div>

        <div>
          <%= f.label :end_date, "Date de fin", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.date_field :end_date, class: "block w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-indigo-500",
                value: @edition.end_date %>
        </div>

        <div>
          <%= f.label :helloasso_form_slug, "Slug HelloAsso", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :helloasso_form_slug, class: "block w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-indigo-500",
                value: @edition.helloasso_form_slug %>
        </div>

        <div>
          <%= f.label :km_rate_cents, "Taux km (€/km)", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :km_rate_cents, class: "block w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-indigo-500",
                value: decimal_km_rate(@edition.km_rate_cents), inputmode: "decimal", data: { controller: "currency-input" } %>
        </div>

        <div>
          <%= f.label :transport_modes, "Modes de transport (un par ligne)", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_area :transport_modes,
                class: "block w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-indigo-500",
                value: @edition.transport_mode_options.join("\n"),
                rows: 5 %>
        </div>

        <div>
          <%= f.label :allowance_labels, "Libellés d'indemnité (un par ligne)", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_area :allowance_labels,
                class: "block w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-indigo-500",
                value: @edition.allowance_label_options.join("\n"),
                rows: 5 %>
        </div>


        <div class="pt-2">
          <%= f.submit "Créer l'édition",
                class: "bg-indigo-600 text-white px-4 py-2 rounded hover:bg-indigo-700 cursor-pointer" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
