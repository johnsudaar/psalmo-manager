<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-semibold text-gray-900">Changements d'atelier</h1>
</div>

<div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 mb-6">
  <%= form_with url: workshop_substitutions_path, method: :get do |f| %>
    <div class="flex gap-4 items-end">
      <div>
        <%= f.label :q, "Rechercher un participant", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :q, value: params[:q],
              placeholder: "Nom ou prénom…",
              class: "border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-indigo-500 w-64" %>
      </div>
      <%= f.submit "Rechercher",
            class: "bg-indigo-600 text-white px-4 py-2 rounded hover:bg-indigo-700 cursor-pointer" %>
    </div>
  <% end %>
</div>

<% if params[:q].present? %>
  <% if @people.any? %>
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-200">
        <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wide">Résultats</h2>
      </div>
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-sm font-semibold text-gray-500 uppercase tracking-wide">Nom</th>
            <th class="px-6 py-3 text-left text-sm font-semibold text-gray-500 uppercase tracking-wide">Email</th>
            <th class="px-6 py-3 text-left text-sm font-semibold text-gray-500 uppercase tracking-wide">Inscriptions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% @people.each_with_index do |person, i| %>
            <% registrations = person.registrations.where(edition_id: current_edition.id) %>
            <tr class="<%= i.even? ? 'bg-white' : 'bg-gray-50' %>">
              <td class="px-6 py-4 text-sm font-medium text-gray-900"><%= person.full_name %></td>
              <td class="px-6 py-4 text-sm text-gray-700"><%= person.email %></td>
              <td class="px-6 py-4 text-sm">
                <div class="flex flex-col gap-1">
                  <% registrations.each do |reg| %>
                    <%= link_to "Sélectionner (inscription ##{reg.helloasso_ticket_id})",
                          new_workshop_substitution_path(registration_id: reg.id),
                          class: "text-indigo-600 hover:text-indigo-800 text-sm font-medium" %>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <p class="text-sm text-gray-500">Aucun participant trouvé pour « <%= params[:q] %> ».</p>
  <% end %>
<% end %>
