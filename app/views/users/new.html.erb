<div class="max-w-xl">
  <div class="flex items-center gap-4 mb-6">
    <%= link_to "← Utilisateurs", users_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
    <h1 class="text-2xl font-semibold text-gray-900">Nouvel utilisateur</h1>
  </div>

  <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
    <% if @user.errors.any? %>
      <div class="mb-4 rounded border border-red-200 bg-red-50 p-3 text-sm text-red-700">
        <%= @user.errors.full_messages.join(", ") %>
      </div>
    <% end %>

    <%= form_with model: @user do |f| %>
      <div class="space-y-4">
        <div>
          <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.email_field :email, class: "w-full border border-gray-300 rounded px-3 py-2 text-sm" %>
        </div>

        <div>
          <%= f.label :password, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.password_field :password, class: "w-full border border-gray-300 rounded px-3 py-2 text-sm" %>
        </div>

        <div>
          <%= f.label :password_confirmation, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.password_field :password_confirmation, class: "w-full border border-gray-300 rounded px-3 py-2 text-sm" %>
        </div>
      </div>

      <div class="mt-6">
        <%= f.submit "Créer l'utilisateur",
              class: "bg-indigo-600 text-white px-4 py-2 rounded hover:bg-indigo-700 cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>
