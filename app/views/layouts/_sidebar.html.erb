<nav class="w-56 bg-white border-r border-gray-200 flex flex-col shrink-0">
  <div class="px-4 py-5 border-b border-gray-200">
    <h1 class="text-sm font-bold text-indigo-600 uppercase tracking-widest">Psalmo Manager</h1>
    <% if current_edition %>
      <%= form_with url: update_edition_session_path, method: :patch, data: { controller: "edition-switcher" } do |f| %>
        <%= f.select :edition_id,
              Edition.ordered.map { |e| [e.name, e.id] },
              {},
              class: "mt-2 block w-full text-xs border-gray-300 rounded",
              selected: current_edition.id,
              data: { action: "change->edition-switcher#submit" } %>
      <% end %>
    <% end %>
  </div>

  <div class="flex-1 px-2 py-4 space-y-1">
    <%= link_to "Tableau de bord", root_path,
          class: "block px-3 py-2 rounded text-sm font-medium #{current_page?(root_path) ? 'bg-indigo-50 text-indigo-700' : 'text-gray-700 hover:bg-gray-50'}" %>

    <div class="pt-3 pb-1 px-3 text-xs font-semibold text-gray-400 uppercase tracking-wider">Inscriptions</div>
    <%= link_to "Participants", participants_path,
          class: "block px-3 py-2 rounded text-sm text-gray-700 hover:bg-gray-50" %>
    <%= link_to "Commandes", orders_path,
          class: "block px-3 py-2 rounded text-sm text-gray-700 hover:bg-gray-50" %>
    <%= link_to "Ateliers", workshops_path,
          class: "block px-3 py-2 rounded text-sm text-gray-700 hover:bg-gray-50" %>

    <div class="pt-3 pb-1 px-3 text-xs font-semibold text-gray-400 uppercase tracking-wider">Staff</div>
    <%= link_to "Fiches staff", staff_profiles_path,
          class: "block px-3 py-2 rounded text-sm text-gray-700 hover:bg-gray-50" %>

    <div class="pt-3 pb-1 px-3 text-xs font-semibold text-gray-400 uppercase tracking-wider">Import / Export</div>
    <%= link_to "Import / Export", export_path,
          class: "block px-3 py-2 rounded text-sm text-gray-700 hover:bg-gray-50" %>
    <%= link_to "Paramètres", editions_path,
          class: "block px-3 py-2 rounded text-sm text-gray-700 hover:bg-gray-50" %>
  </div>

  <div class="px-2 py-4 border-t border-gray-200">
    <%= button_to "Se déconnecter", destroy_user_session_path, method: :delete,
          class: "block w-full text-left px-3 py-2 rounded text-sm text-gray-700 hover:bg-gray-50" %>
  </div>
</nav>
