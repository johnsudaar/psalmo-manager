<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-semibold text-gray-900">Commandes — <%= current_edition.name %></h1>
</div>

<%= form_with url: orders_path, method: :get,
      class: "bg-white rounded-lg shadow-sm border border-gray-200 p-4 mb-6" do |f| %>
  <div class="flex flex-wrap gap-4 items-end">
    <div>
      <%= f.label :date_from, "Du", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.date_field :date_from, value: params[:date_from],
            class: "border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
    </div>
    <div>
      <%= f.label :date_to, "Au", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.date_field :date_to, value: params[:date_to],
            class: "border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
    </div>
    <div>
      <%= f.label :status, "Statut", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.select :status,
            [["Tous", ""], ["En attente", "pending"], ["Confirmée", "confirmed"], ["Annulée", "cancelled"], ["Remboursée", "refunded"]],
            { selected: params[:status] },
            class: "border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
    </div>
    <div>
      <%= f.label :promo_code, "Code promo", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :promo_code, value: params[:promo_code],
            class: "border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
    </div>
    <%= f.submit "Filtrer", class: "bg-white text-gray-700 border border-gray-300 px-4 py-2 rounded hover:bg-gray-50 cursor-pointer" %>
  </div>
<% end %>

<div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-6 py-3 text-left text-sm font-semibold text-gray-500 uppercase tracking-wide">ID HelloAsso</th>
        <th class="px-6 py-3 text-left text-sm font-semibold text-gray-500 uppercase tracking-wide">Date</th>
        <th class="px-6 py-3 text-left text-sm font-semibold text-gray-500 uppercase tracking-wide">Payeur</th>
        <th class="px-6 py-3 text-left text-sm font-semibold text-gray-500 uppercase tracking-wide">Statut</th>
        <th class="px-6 py-3 text-left text-sm font-semibold text-gray-500 uppercase tracking-wide">Inscriptions</th>
        <th class="px-6 py-3 text-left text-sm font-semibold text-gray-500 uppercase tracking-wide">Montant promo</th>
        <th class="px-6 py-3 text-left text-sm font-semibold text-gray-500 uppercase tracking-wide">Actions</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200">
      <% @orders.each_with_index do |order, i| %>
        <tr class="<%= i.even? ? 'bg-white' : 'bg-gray-50' %>">
          <td class="px-6 py-4 text-sm font-mono text-gray-900"><%= order.helloasso_order_id %></td>
          <td class="px-6 py-4 text-sm text-gray-700"><%= order.order_date&.strftime("%d/%m/%Y") %></td>
          <td class="px-6 py-4 text-sm text-gray-700"><%= order.payer&.full_name || "—" %></td>
          <td class="px-6 py-4 text-sm">
            <% badge_class = case order.status
               when "confirmed" then "bg-green-100 text-green-800"
               when "cancelled" then "bg-red-100 text-red-800"
               when "refunded"  then "bg-yellow-100 text-yellow-800"
               else "bg-gray-100 text-gray-600"
               end %>
            <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium <%= badge_class %>">
              <%= order.status %>
            </span>
          </td>
          <td class="px-6 py-4 text-sm text-gray-700"><%= order.registrations.count %></td>
          <td class="px-6 py-4 text-sm text-gray-700">
            <%= order.promo_code.present? ? "#{order.promo_code} (#{format_euros(order.promo_amount_cents)})" : "—" %>
          </td>
          <td class="px-6 py-4 text-sm">
            <%= link_to "Voir", order_path(order),
                  class: "text-indigo-600 hover:text-indigo-800 font-medium" %>
          </td>
        </tr>
      <% end %>
      <% if @orders.empty? %>
        <tr>
          <td colspan="7" class="px-6 py-8 text-center text-sm text-gray-500">Aucune commande trouvée.</td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<% if @pagy.pages > 1 %>
  <div class="mt-4 flex justify-center text-sm">
    <%== pagy_nav(@pagy) %>
  </div>
<% end %>
